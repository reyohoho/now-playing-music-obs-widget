{
    "version": "1.0.0",
    "manifest_version": 3,
    "name": "OBS now playing",
    "description": "OBS now playing",
    "permissions": ["tabs", "storage"],
    "host_permissions": [
      "http://127.0.0.1:4455/*", "http://localhost:4455/*",
      "wss://irc-ws.chat.twitch.tv/*"
    ],
    "minimum_chrome_version": "116",
    "externally_connectable": {
      "matches": [
        "https://music.yandex.ru/*",
        "https://music.yandex.com/*",
        "https://music.yandex.by/*",
        "https://music.yandex.kz/*",
        "https://moo.bot/*",
        "https://www.donationalerts.com/*",
        "https://donationalerts.com/*",
        "https://hobot.alwaysdata.net/*",
        "https://streamelements.com/*",
        "https://open.spotify.com/*",
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*",
        "https://music.youtube.com/*",
        "https://www.youtube-nocookie.com/*",
        "https://youtu.be/*",
        "https://soundcloud.com/*",
        "https://www.soundcloud.com/*",
        "https://vk.com/*",
        "https://www.vk.com/*",
        "https://m.vk.com/*",
        "https://www.radiorecord.ru/*",
        "https://radiorecord.ru/*"
      ]
    },
    "options_ui": { "page": "options.html", "open_in_tab": true },
    "background": { "service_worker": "background.js" },
    "content_scripts": [
      {
        "js": [
          "content.js"
        ],

        "matches": [
          "https://music.yandex.ru/*",
          "https://music.yandex.com/*",
          "https://music.yandex.by/*",
          "https://music.yandex.kz/*",
          "https://moo.bot/*",
          "https://www.donationalerts.com/*",
          "https://donationalerts.com/*",
          "https://hobot.alwaysdata.net/*",
          "https://streamelements.com/*",
          "https://open.spotify.com/*",
          "https://www.youtube.com/*",
          "https://youtube.com/*",
          "https://m.youtube.com/*",
          "https://music.youtube.com/*",
          "https://www.youtube-nocookie.com/*",
          "https://youtu.be/*",
          "https://soundcloud.com/*",
          "https://www.soundcloud.com/*",
          "https://vk.com/*",
          "https://www.vk.com/*",
          "https://m.vk.com/*",
          "https://www.radiorecord.ru/*",
          "https://radiorecord.ru/*"
        ],
        "run_at": "document_idle"
      }
    ],
    "action": {
      "default_title": "OBS plugin now playing"
    }
  }